{
	"name": "Node(TS) + Terraform",
	"build": {
		"dockerfile": "Dockerfile"
	},

	"remoteUser": "node",

	"customizations": {
		"vscode": {
			"extensions": [
				"-dbaeumer.vscode-eslint",
				"biomejs.biome",
				"YoavBls.pretty-ts-errors",
				"hashicorp.terraform",
				"vitest.explorer",
				"github.vscode-github-actions"
			],
			"settings": {
				"js/ts.tsdk.path": "node_modules/typescript/lib",
				"editor.defaultFormatter": "biomejs.biome"
			}
		}
	},

	"containerEnv": {
		"TZ": "Asia/Tokyo"
	}
}
